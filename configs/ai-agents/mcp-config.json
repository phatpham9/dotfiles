{
  "mcpServers": {
    "github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "huggingface": {
      "type": "http",
      "url": "https://huggingface.co/mcp?login"
    },
    "next-devtools": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "next-devtools-mcp"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "chrome-devtools-mcp"]
    },
    "markitdown": {
      "type": "stdio",
      "command": "uvx",
      "args": ["markitdown-mcp"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp/oauth"
    },
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "arxiv-mcp-server": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "tool",
        "run",
        "arxiv-mcp-server",
        "--storage-path",
        "~/.cache/arxiv-mcp-server"
      ]
    }
  }
}
